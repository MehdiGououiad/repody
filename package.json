{
  "name": "agentcontrol",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.11.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "@swc/core",
      "sharp",
      "unrs-resolver"
    ]
  },
  "scripts": {
    "platform:start": "node scripts/container-stack.mjs start",
    "platform:start:warm": "node scripts/container-stack.mjs start:warm",
    "platform:stop": "node scripts/container-stack.mjs stop",
    "platform:logs": "node scripts/docker.mjs logs:selective",
    "containers:start": "node scripts/container-stack.mjs start",
    "containers:start:warm": "node scripts/container-stack.mjs start:warm",
    "containers:stop": "node scripts/container-stack.mjs stop",
    "dev": "pnpm dev:ui",
    "dev:ui": "next dev --turbo",
    "dev:nowarmup": "node scripts/dev-stack.mjs nowarmup",
    "dev:warmup": "node scripts/dev-stack.mjs warmup",
    "dev:rebuild": "node scripts/dev-stack.mjs nowarmup --rebuild",
    "dev:stop": "node scripts/stop-stack.mjs",
    "build": "next build",
    "codegen:api": "cd backend && python scripts/export_openapi.py && cd .. && openapi-typescript lib/api/openapi.json -o lib/api/generated/schema.d.ts",
    "start": "node scripts/prepare-standalone.mjs && node .next/standalone/server.js",
    "lint": "eslint",
    "test:api": "cd backend && python -m pytest tests/ -v -m \"not live\"",
    "test:api:e2e": "cd backend && python -m pytest tests/test_api/test_api_e2e_suite.py -v --tb=short",
    "test:api:live": "cd backend && python -m pytest tests/test_api/test_live_api_e2e.py -v -m live --tb=short",
    "test:facture": "cd backend && python -m pytest tests/test_e2e/test_facture_ui_e2e.py -v -m \"e2e_facture and not live\" --tb=short",
    "test:facture:docker": "node scripts/test-facture.mjs docker",
    "test:facture:stack": "node scripts/test-facture.mjs stack",
    "db:migrate": "cd backend && python -m alembic upgrade head",
    "docker:infra": "node scripts/docker.mjs infra",
    "docker:wait:api": "node scripts/wait-for-api.mjs",
    "docker:models:pull": "node scripts/prepare-repody-vlm-model.mjs",
    "docker:models:pull:repody-vlm": "node scripts/prepare-repody-vlm-model.mjs",
    "docker:models:pull:validation": "node scripts/prepare-validation-model.mjs",
    "benchmark:document-models": "node scripts/benchmark.mjs document-models",
    "benchmark:quick": "node scripts/benchmark.mjs quick",
    "benchmark:models": "node scripts/benchmark.mjs models",
    "benchmark:suite": "node scripts/benchmark.mjs full",
    "docker:wait:warmup": "node scripts/wait-for-warmup.mjs",
    "docker:infra:warmup": "node scripts/docker.mjs infra:warmup",
    "docker:services:warmup": "node scripts/docker.mjs services:warmup",
    "docker:services": "node scripts/docker.mjs services",
    "docker:up": "node scripts/docker.mjs up",
    "docker:up:warm": "node scripts/docker.mjs up:warmup",
    "docker:up:build": "node scripts/docker.mjs up:build",
    "docker:up:web-docker": "node scripts/docker.mjs up:web-docker",
    "docker:up:web-docker:warm": "node scripts/docker.mjs up:web-docker:warmup",
    "docker:watch": "node scripts/docker.mjs watch",
    "docker:restart:workers": "node scripts/docker.mjs restart:workers",
    "docker:build:backend": "node scripts/docker.mjs build:backend",
    "docker:build:web": "node scripts/docker.mjs build:web",
    "docker:down": "node scripts/docker.mjs down",
    "docker:down:warm": "node scripts/docker.mjs down:warmup",
    "docker:deploy": "node scripts/docker.mjs deploy",
    "docker:configure:lan": "node scripts/configure-lan.mjs",
    "docker:deploy:lan": "node scripts/docker.mjs deploy:lan",
    "docker:deploy:public": "node scripts/docker.mjs deploy:public",
    "docker:deploy:cloud": "node scripts/docker.mjs deploy:cloud",
    "docker:deploy:scale": "node scripts/docker.mjs deploy:scale",
    "docker:scale:workers": "node scripts/docker.mjs scale:workers",
    "docker:deploy:gpu": "node scripts/docker.mjs deploy:gpu",
    "docker:verify:gpu": "node scripts/verify-compose-gpu.mjs",
    "docker:deploy:obs": "node scripts/docker.mjs deploy:obs",
    "platform:modules": "node scripts/platform.mjs modules",
    "platform:stacks": "node scripts/platform.mjs stacks",
    "platform:up": "node scripts/platform.mjs up",
    "platform:down": "node scripts/platform.mjs down",
    "platform:logs": "node scripts/platform.mjs logs",
    "platform:scale": "node scripts/platform.mjs scale",
    "platform:images:build": "node scripts/build-images.mjs",
    "platform:images:push": "node scripts/build-images.mjs --push",
    "helm:deps": "node scripts/helm-deps.mjs",
    "helm:template": "helm template audit deploy/helm/audit-platform",
    "helm:lint": "helm lint deploy/helm/audit-platform",
    "docker:glitchtip:up": "node scripts/platform.mjs up --modules-only --with=errors --detach",
    "docker:glitchtip:down": "node scripts/docker.mjs glitchtip:down",
    "docker:deploy:glitchtip": "node scripts/docker.mjs deploy:glitchtip",
    "docker:up:obs": "node scripts/docker.mjs up:obs",
    "docker:up:full": "node scripts/docker.mjs up:full",
    "docker:up:gpu": "node scripts/docker.mjs deploy:gpu",
    "docker:obs": "docker compose -f compose.observability.yaml --profile obs up -d",
    "docker:logs:platform": "node scripts/docker.mjs logs",
    "test:platform:integration": "cd backend && python scripts/platform_integration_suite.py",
    "test:platform:api": "cd backend && python -m pytest tests/test_platform -v -m live",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test e2e/tests/01-platform-smoke.spec.ts",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:platform": "node scripts/run-platform-e2e.mjs",
    "dev:api": "cd backend && uvicorn audit_workbench.main:app --reload --port 8000"
  },
  "dependencies": {
    "@microsoft/fetch-event-source": "^2.0.1",
    "@radix-ui/react-collapsible": "^1.1.13",
    "@radix-ui/react-dialog": "^1.1.16",
    "@radix-ui/react-dropdown-menu": "^2.1.17",
    "@radix-ui/react-label": "^2.1.9",
    "@radix-ui/react-popover": "^1.1.16",
    "@radix-ui/react-progress": "^1.1.9",
    "@radix-ui/react-scroll-area": "^1.2.11",
    "@radix-ui/react-select": "^2.3.0",
    "@radix-ui/react-separator": "^1.1.9",
    "@radix-ui/react-slot": "^1.2.5",
    "@radix-ui/react-tabs": "^1.1.14",
    "@radix-ui/react-tooltip": "^1.2.9",
    "@sentry/nextjs": "^10.57.0",
    "@tanstack/react-query": "^5.101.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "lucide-react": "^1.18.0",
    "next": "16.2.9",
    "next-intl": "^4.13.0",
    "next-themes": "^0.4.6",
    "openapi-fetch": "^0.17.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.11.2",
    "recharts": "^3.8.1",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^10.5.0",
    "eslint-config-next": "16.2.9",
    "openapi-typescript": "^7.13.0",
    "tailwindcss": "^4.3.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3"
  }
}
