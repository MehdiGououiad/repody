{
  "name": "repody",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "private": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/MehdiGououiad/repody.git"
  },
  "engines": {
    "node": ">=24 <25",
    "pnpm": "11.7.0"
  },
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "doctor": "node scripts/check-toolchain.mjs",
    "dev": "node deploy/scripts/local-dev.mjs stack",
    "dev:setup": "node deploy/scripts/local-dev.mjs setup",
    "dev:stack": "node deploy/scripts/local-dev.mjs stack",
    "dev:app": "node deploy/scripts/local-dev.mjs app",
    "dev:all": "node deploy/scripts/local-dev.mjs all",
    "dev:status": "node deploy/scripts/local-dev.mjs status",
    "dev:stop": "node deploy/scripts/local-dev.mjs stop",
    "dev:restart": "node deploy/scripts/local-dev.mjs restart",
    "dev:down": "node deploy/scripts/local-dev.mjs stop",
    "dev:api": "node deploy/scripts/local-dev.mjs api",
    "dev:worker": "docker compose --profile workers up -d --build worker-ocr worker-fast",
    "dev:worker:ocr": "docker compose --profile workers up -d --build worker-ocr",
    "dev:worker:fast": "docker compose --profile workers up -d --build worker-fast",
    "dev:worker:native": "node deploy/scripts/run-worker.mjs ocr",
    "ui": "next dev --turbo",
    "build": "next build",
    "codegen:api": "pnpm codegen:api:export && pnpm codegen:api:types",
    "codegen:api:export": "node scripts/backend-run.mjs python scripts/export_openapi.py",
    "codegen:api:types": "openapi-typescript lib/api/openapi.json -o lib/api/generated/schema.d.ts",
    "start": "node scripts/prepare-standalone.mjs && node .next/standalone/server.js",
    "lint": "eslint app components lib proxy.ts",
    "typecheck": "tsc --noEmit",
    "test:auth": "node scripts/backend-run.mjs --dev pytest tests/test_auth -q",
    "test:api": "node scripts/backend-run.mjs --dev pytest tests/ -v -m \"not live\"",
    "test:api:e2e": "node scripts/backend-run.mjs --dev pytest tests/test_api/test_api_e2e_suite.py -v --tb=short -m \"not live\"",
    "test:api:e2e:fast": "node scripts/backend-run.mjs --dev pytest tests/test_api/test_api_e2e_suite.py -v --tb=short -m \"not live and not slow\"",
    "test:api:live": "node scripts/backend-run.mjs --dev pytest tests/test_api/test_live_api_e2e.py tests/test_platform tests/test_e2e/test_facture_ui_e2e.py -v -m live --tb=short",
    "test:platform:live": "node scripts/backend-run.mjs --dev pytest tests/test_platform tests/test_api/test_live_api_e2e.py tests/test_e2e/test_facture_ui_e2e.py -v -m live --tb=short",
    "test:facture": "node scripts/backend-run.mjs --dev pytest tests/test_e2e/test_facture_ui_e2e.py -v -m \"e2e_facture and live\" --tb=short",
    "db:migrate": "node scripts/backend-run.mjs alembic upgrade head",
    "db:reset": "node scripts/backend-run.mjs python scripts/db_reset.py",
    "wait:api": "node scripts/wait-for-api.mjs",
    "wait:warmup": "node scripts/wait-for-warmup.mjs",
    "client:check": "node deploy/scripts/client-integration-check.mjs",
    "deploy:check": "node deploy/scripts/deploy-check.mjs",
    "enterprise:secrets": "node deploy/scripts/check-enterprise-secrets.mjs",
    "deploy:staging": "node deploy/scripts/deploy-staging.mjs",
    "images:build": "node deploy/scripts/build-images.mjs",
    "images:push": "node deploy/scripts/build-images.mjs --push-only",
    "images:release": "node deploy/scripts/build-images.mjs --push",
    "release:attest": "node deploy/scripts/release-supply-chain.mjs attest",
    "release:verify": "node deploy/scripts/release-supply-chain.mjs verify",
    "release:manifest": "node deploy/scripts/release-supply-chain.mjs manifest",
    "release:promote": "node deploy/scripts/release-supply-chain.mjs promote",
    "release:all": "node deploy/scripts/build-images.mjs --push && node deploy/scripts/release-supply-chain.mjs attest && node deploy/scripts/release-supply-chain.mjs promote --channel=staging",
    "openshift:promote": "node deploy/scripts/openshift-local-promote.mjs all",
    "openshift:preflight": "node deploy/scripts/openshift-local-promote.mjs preflight",
    "openshift:client-ready": "node deploy/scripts/check-openshift-client-ready.mjs",
    "k3s:client": "node deploy/scripts/k3s-client-bundled.mjs all",
    "k3s:client:clean": "node deploy/scripts/k3s-client-bundled.mjs clean",
    "enterprise:lab": "node deploy/scripts/enterprise-gitops-lab.mjs all",
    "enterprise:lab:sync": "node deploy/scripts/enterprise-gitops-lab.mjs sync",
    "airgap:build": "node deploy/scripts/airgap-build-release.mjs",
    "airgap:import": "node deploy/scripts/airgap-import.mjs",
    "helm:deps": "node scripts/helm-deps.mjs",
    "helm:deps:check": "node scripts/helm-deps.mjs --check",
    "helm:deps:update": "node scripts/helm-deps.mjs --update",
    "helm:lint": "helm lint deploy/helm/repody-data && helm lint deploy/helm/repody-auth && helm lint deploy/helm/repody",
    "helm:template": "helm template repody deploy/helm/repody",
    "llamacpp:serve": "node deploy/scripts/llamacpp-nuextract3.mjs serve",
    "llamacpp:stop": "node deploy/scripts/llamacpp-nuextract3.mjs stop",
    "llamacpp:restart": "node deploy/scripts/llamacpp-nuextract3.mjs restart",
    "llamacpp:verify": "node deploy/scripts/llamacpp-nuextract3.mjs verify",
    "llamacpp:warmup": "node deploy/scripts/llamacpp-nuextract3.mjs warmup",
    "test:platform:integration": "node scripts/backend-run.mjs --dev python scripts/platform_integration_suite.py",
    "test:platform:api": "node scripts/backend-run.mjs --dev pytest tests/test_platform -v -m live",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test e2e/tests/01-platform-smoke.spec.ts",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:platform": "node scripts/run-platform-e2e.mjs",
    "benchmark": "node scripts/benchmark.mjs"
  },
  "dependencies": {
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource-variable/source-sans-3": "^5.2.9",
    "@microsoft/fetch-event-source": "^2.0.1",
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-dropdown-menu": "^2.1.18",
    "@radix-ui/react-label": "^2.1.10",
    "@radix-ui/react-popover": "^1.1.17",
    "@radix-ui/react-progress": "^1.1.10",
    "@radix-ui/react-scroll-area": "^1.2.12",
    "@radix-ui/react-select": "^2.3.1",
    "@radix-ui/react-separator": "^1.1.10",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-tabs": "^1.1.15",
    "@radix-ui/react-tooltip": "^1.2.10",
    "@sentry/nextjs": "^10.58.0",
    "@tanstack/react-query": "^5.101.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "lucide-react": "^1.18.0",
    "next": "16.2.9",
    "next-auth": "5.0.0-beta.30",
    "next-intl": "^4.13.0",
    "next-themes": "^0.4.6",
    "openapi-fetch": "^0.17.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.11.2",
    "recharts": "^3.8.1",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^10.5.0",
    "eslint-config-next": "16.2.9",
    "openapi-typescript": "^7.13.0",
    "tailwindcss": "^4.3.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3"
  }
}
