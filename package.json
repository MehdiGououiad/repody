{
  "name": "repody",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "private": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/MehdiGououiad/repody.git"
  },
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "dev": "node deploy/scripts/k8s-local.mjs up --minimal --fast",
    "dev:trace": "node deploy/scripts/k8s-local.mjs up --minimal --trace",
    "dev:fast": "node deploy/scripts/k8s-local.mjs up --minimal --fast",
    "dev:full": "pnpm k8s:local",
    "dev:build": "node deploy/scripts/k8s-local.mjs up --minimal --build",
    "dev:sync": "node deploy/scripts/skaffold-dev.mjs",
    "registry:warm": "node deploy/scripts/k8s-local.mjs warm-registry",
    "harbor:prepare": "node deploy/scripts/harbor-local.mjs prepare",
    "harbor:up": "node deploy/scripts/harbor-local.mjs up",
    "harbor:down": "node deploy/scripts/harbor-local.mjs down",
    "harbor:login": "node deploy/scripts/harbor-local.mjs login",
    "harbor:project": "node deploy/scripts/harbor-local.mjs project",
    "harbor:connect-kind": "node deploy/scripts/harbor-local.mjs connect-kind",
    "harbor:bootstrap": "node deploy/scripts/harbor-local.mjs bootstrap",
    "stop": "node deploy/scripts/k8s-local.mjs down",
    "stop:cluster": "node deploy/scripts/k8s-local.mjs down --cluster",
    "ui": "next dev --turbo",
    "build": "next build",
    "codegen:api": "cd backend && python scripts/export_openapi.py && cd .. && openapi-typescript lib/api/openapi.json -o lib/api/generated/schema.d.ts",
    "start": "node scripts/prepare-standalone.mjs && node .next/standalone/server.js",
    "lint": "eslint app components lib proxy.ts",
    "test:auth": "cd backend && python -m pytest tests/test_auth -q",
    "test:api": "cd backend && python -m pytest tests/ -v -m \"not live\"",
    "test:api:e2e": "cd backend && python -m pytest tests/test_api/test_api_e2e_suite.py -v --tb=short -m \"not live\"",
    "test:api:e2e:fast": "cd backend && python -m pytest tests/test_api/test_api_e2e_suite.py -v --tb=short -m \"not live and not slow\"",
    "test:api:live": "cd backend && python -m pytest tests/test_api/test_live_api_e2e.py tests/test_platform tests/test_e2e/test_facture_ui_e2e.py -v -m live --tb=short",
    "test:platform:live": "cd backend && python -m pytest tests/test_platform tests/test_api/test_live_api_e2e.py tests/test_e2e/test_facture_ui_e2e.py -v -m live --tb=short",
    "test:facture": "cd backend && python -m pytest tests/test_e2e/test_facture_ui_e2e.py -v -m \"e2e_facture and live\" --tb=short",
    "test:facture:unit": "node scripts/test-facture.mjs unit",
    "test:facture:live": "node scripts/test-facture.mjs live",
    "db:migrate": "cd backend && python -m alembic upgrade head",
    "platform:reset": "node deploy/scripts/platform-reset.mjs",
    "wait:api": "node scripts/wait-for-api.mjs",
    "wait:warmup": "node scripts/wait-for-warmup.mjs",
    "deploy:check": "node deploy/scripts/deploy-check.mjs",
    "enterprise:secrets": "node deploy/scripts/check-enterprise-secrets.mjs",
    "deploy:staging": "node deploy/scripts/deploy-staging.mjs",
    "images:build": "node deploy/scripts/build-images.mjs",
    "images:push": "node deploy/scripts/build-images.mjs --push",
    "gitops:publish": "node deploy/scripts/gitops-publish-local.mjs",
    "gitops:sync": "node deploy/scripts/gitops-sync-local.mjs",
    "airgap:build": "node deploy/scripts/airgap-build-release.mjs",
    "airgap:import": "node deploy/scripts/airgap-import.mjs",
    "helm:deps": "node scripts/helm-deps.mjs",
    "helm:template": "helm template repody deploy/helm/repody",
    "helm:lint": "helm lint deploy/helm/repody",
    "k8s:data:render": "kubectl kustomize deploy/managed/cloudnativepg",
    "k8s:local": "node deploy/scripts/k8s-local.mjs up",
    "k8s:local:reset": "node deploy/scripts/k8s-local.mjs up --reset",
    "k8s:local:down": "pnpm stop",
    "k8s:local:down:cluster": "pnpm stop:cluster",
    "k8s:local:status": "node deploy/scripts/k8s-local.mjs status",
    "k8s:local:deploy": "pnpm dev:fast",
    "k8s:local:smoke": "node deploy/scripts/k8s-local-smoke.mjs",
    "k8s:local:hosts": "node deploy/scripts/k8s-local.mjs hosts",
    "k8s:local:logs": "node deploy/scripts/k8s-local.mjs logs",
    "llamacpp:serve": "node deploy/scripts/llamacpp-nuextract3.mjs serve",
    "llamacpp:verify": "node deploy/scripts/llamacpp-nuextract3.mjs verify",
    "llamacpp:surya:serve": "node deploy/scripts/llamacpp-surya-ocr2.mjs serve",
    "llamacpp:surya:verify": "node deploy/scripts/llamacpp-surya-ocr2.mjs verify",
    "llamacpp:surya:stop": "node deploy/scripts/llamacpp-surya-ocr2.mjs stop",
    "test:platform:integration": "cd backend && python scripts/platform_integration_suite.py",
    "test:platform:api": "cd backend && python -m pytest tests/test_platform -v -m live",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test e2e/tests/01-platform-smoke.spec.ts",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:platform": "node scripts/run-platform-e2e.mjs",
    "dev:api": "cd backend && uvicorn audit_workbench.main:app --reload --port 8000",
    "benchmark": "node scripts/benchmark.mjs"
  },
  "dependencies": {
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource-variable/source-sans-3": "^5.2.9",
    "@microsoft/fetch-event-source": "^2.0.1",
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-dropdown-menu": "^2.1.18",
    "@radix-ui/react-label": "^2.1.10",
    "@radix-ui/react-popover": "^1.1.17",
    "@radix-ui/react-progress": "^1.1.10",
    "@radix-ui/react-scroll-area": "^1.2.12",
    "@radix-ui/react-select": "^2.3.1",
    "@radix-ui/react-separator": "^1.1.10",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-tabs": "^1.1.15",
    "@radix-ui/react-tooltip": "^1.2.10",
    "@sentry/nextjs": "^10.58.0",
    "@tanstack/react-query": "^5.101.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "lucide-react": "^1.18.0",
    "next": "16.2.9",
    "next-auth": "5.0.0-beta.30",
    "next-intl": "^4.13.0",
    "next-themes": "^0.4.6",
    "openapi-fetch": "^0.17.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.11.2",
    "recharts": "^3.8.1",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^10.5.0",
    "eslint-config-next": "16.2.9",
    "openapi-typescript": "^7.13.0",
    "tailwindcss": "^4.3.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3"
  }
}
