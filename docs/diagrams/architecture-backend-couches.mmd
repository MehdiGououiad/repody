flowchart TB
  subgraph Presentation["Couche présentation"]
    Next["Next.js App Router<br/>app/ · components/"]
    Proxy["proxy.ts<br/>Auth.js + Bearer vers /api/v1"]
    APIRouters["FastAPI routers<br/>api/workflows · runs · uploads<br/>platform · operator"]
  end

  subgraph Application["Couche application / services"]
    WFSvc["services/workflow/<br/>CRUD · deploy · API key"]
    RunEnq["services/run_enqueue.py<br/>admission · create Run"]
    Outbox["services/dispatch_outbox.py<br/>outbox Postgres"]
    Dispatch["services/run_dispatch.py<br/>Taskiq kiq"]
    RunProc["services/run_processor.py<br/>claim · phases"]
    RunExt["services/run/extraction.py"]
    RunVal["services/run/validation.py"]
    OpSvc["services/operator/<br/>diagnostics · warmup"]
  end

  subgraph Domaine["Domaine audit execution"]
    Domain["services/run/domain/<br/>entité · cycle de vie"]
    Events["Événements domaine<br/>RunQueued · Started<br/>Completed · Failed"]
  end

  subgraph Extraction["Extraction & catalogue"]
    Pipe["extraction/pipeline.py<br/>PipelineExtractor"]
    Catalog["catalog/registry.py<br/>repody:vlm"]
    VLM["extraction/repody_vlm_extract.py<br/>PDF→PNG→NuExtract"]
    Rules["rules/runner.py<br/>logic + LLM"]
  end

  subgraph Infra["Infrastructure"]
    DB["db/ SQLAlchemy + Alembic"]
    Storage["storage/ MinIO ou local"]
    Taskiq["taskiq/ broker Redis Streams<br/>queues extract | fast"]
    InfClient["inference/ clients OpenAI-compat"]
    Auth["auth/ JWT · Casbin RBAC"]
  end

  Next --> Proxy --> APIRouters
  APIRouters --> WFSvc
  APIRouters --> RunEnq
  APIRouters --> Auth
  RunEnq --> Outbox --> Dispatch --> Taskiq
  Taskiq --> RunProc
  RunProc --> Domain
