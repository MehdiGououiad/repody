# On-prem managed-data override.
# Use with values-production.yaml.example and values-production.gateway.yaml.example.

postgresql:
  enabled: false

externalDatabase:
  enabled: true
  existingSecret: repody-runtime-secrets
  urlKey: AUDIT_DATABASE_URL

redis:
  enabled: false

externalRedis:
  enabled: true
  existingSecret: repody-runtime-secrets
  urlKey: AUDIT_REDIS_URL

minio:
  enabled: false

externalObjectStorage:
  enabled: true
  endpoint: minio.yourdomain.com
  bucket: audit-documents
  existingSecret: repody-runtime-secrets
  accessKeyKey: AUDIT_MINIO_ACCESS_KEY
  secretKeyKey: AUDIT_MINIO_SECRET_KEY
  secure: true
  publicEndpoint: files.yourdomain.com

secrets:
  create: false
  existingSecret: repody-runtime-secrets

observability:
  existingSecret: repody-runtime-secrets
  bugsinkDsnKey: BUGSINK_DSN
  otelEnabled: true
  otelEndpoint: http://otel-collector.monitoring.svc.cluster.local:4318/v1/traces

migrations:
  enabled: true
