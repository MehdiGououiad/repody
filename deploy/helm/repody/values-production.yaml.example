# Production overrides. Keep this file secret-free for GitOps.
# For Argo CD, commit a real values-production.yaml derived from this file,
# and provide the referenced Kubernetes Secret via External Secrets, Sealed
# Secrets, SOPS, or a manual bootstrap outside Git.

global:
  deploymentEnvironment: production

images:
  api:
    repository: ghcr.io/YOUR_ORG/repody-api
    tag: "0.1.0"
    pullPolicy: IfNotPresent
  worker:
    repository: ghcr.io/YOUR_ORG/repody-worker
    tag: "0.1.0"
    pullPolicy: IfNotPresent
  web:
    repository: ghcr.io/YOUR_ORG/repody-web
    tag: "0.1.0"
    pullPolicy: IfNotPresent

postgresql:
  auth:
    password: ""  # Leave empty for Bitnami-generated secret, or set explicitly outside Git.

minio:
  auth:
    rootPassword: ""  # Set outside Git for deterministic installs.

ingress:
  enabled: true
  className: nginx
  host: app.yourdomain.com
  filesHost: files.yourdomain.com
  tls:
    enabled: true
    secretName: repody-tls

secrets:
  create: false
  existingSecret: repody-runtime-secrets

config:
  oidcIssuer: https://auth.yourdomain.com/realms/repody
  oidcAudience: repody-api
  keycloakClientId: repody-web
  corsOrigins: '["https://app.yourdomain.com"]'
  vllmBaseUrl: http://vllm.gpu.svc.cluster.local:8000/v1
  vllmServedModel: numind/NuExtract3

observability:
  bugsinkDsn: ""  # Optional Bugsink DSN.

hatchet:
  postgresPassword: ""  # Not used when secrets.existingSecret is set.
  bootstrapToken: true

workerOcr:
  replicas: 2
  autoscaling:
    enabled: true
    maxReplicas: 15

workerFast:
  replicas: 2
  autoscaling:
    enabled: true
    maxReplicas: 10
