# Production overrides. Keep this file secret-free for GitOps.
# For Argo CD, commit a real values-production.yaml derived from this file,
# and provide the referenced Kubernetes Secret via External Secrets, Sealed
# Secrets, SOPS, or a manual bootstrap outside Git.

global:
  deploymentEnvironment: production
  # Required when GHCR packages are private. Public GHCR packages can be pulled
  # anonymously, but private enterprise installs should use an imagePullSecret.
  imagePullSecrets:
    - name: ghcr-pull-secret

images:
  backend:
    repository: ghcr.io/YOUR_ORG/repody-backend
    tag: "0.1.0"
    pullPolicy: IfNotPresent
  api:
    repository: ghcr.io/YOUR_ORG/repody-backend
    tag: "0.1.0"
    pullPolicy: IfNotPresent
  worker:
    repository: ghcr.io/YOUR_ORG/repody-backend
    tag: "0.1.0"
    pullPolicy: IfNotPresent
  web:
    repository: ghcr.io/YOUR_ORG/repody-web
    tag: "0.1.0"
    pullPolicy: IfNotPresent

postgresql:
  enabled: false
  auth:
    password: ""

externalDatabase:
  enabled: true
  existingSecret: repody-runtime-secrets
  urlKey: AUDIT_DATABASE_URL

redis:
  enabled: false

externalRedis:
  enabled: true
  existingSecret: repody-runtime-secrets
  urlKey: AUDIT_REDIS_URL

minio:
  enabled: false
  auth:
    rootPassword: ""

externalObjectStorage:
  enabled: true
  endpoint: s3.yourdomain.com
  bucket: audit-documents
  existingSecret: repody-runtime-secrets
  accessKeyKey: AUDIT_MINIO_ACCESS_KEY
  secretKeyKey: AUDIT_MINIO_SECRET_KEY
  secure: true
  publicEndpoint: files.yourdomain.com

ingress:
  enabled: true
  className: nginx
  host: app.yourdomain.com
  # Only routed by this chart when bundled minio.enabled=true.
  # With externalObjectStorage.enabled=true, point DNS/publicEndpoint at the
  # client object-storage service instead.
  filesHost: files.yourdomain.com
  tls:
    enabled: true
    secretName: repody-tls

secrets:
  create: false
  existingSecret: repody-runtime-secrets
  # Put AUDIT_LLAMACPP_API_KEY in this Secret when the external vLLM endpoint requires auth.

config:
  oidcIssuer: https://auth.yourdomain.com/realms/repody
  oidcAudience: repody-api
  keycloakClientId: repody-web
  corsOrigins: '["https://app.yourdomain.com"]'
  # External OpenAI-compatible endpoint: vLLM, llama-server, or managed GPU service.
  llamacppBaseUrl: https://vlm.yourdomain.com/v1
  # Must match the client's llama-server model id (official local: nuextract3-q4_k_m).
  llamacppServedModel: nuextract3-q4_k_m
  workerTaskTimeoutMinutes: 3
  staleRunTimeoutMinutes: 5
  queuedStaleTimeoutMinutes: 60
  dbPoolSize: 5
  redisMaxConnections: 20

observability:
  existingSecret: repody-runtime-secrets
  bugsinkDsnKey: BUGSINK_DSN
  bugsinkDsn: ""  # Optional fallback; prefer observability.existingSecret.
  otelEnabled: true
  otelEndpoint: http://otel-collector.monitoring.svc.cluster.local:4318/v1/traces

migrations:
  enabled: true

workerExtract:
  replicas: 2
  warmupOnStart: false
  resources:
    requests:
      cpu: 250m
      memory: 768Mi
    limits:
      memory: 2Gi
  autoscaling:
    enabled: true
    maxReplicas: 15

workerFast:
  replicas: 2
  resources:
    requests:
      cpu: 100m
      memory: 256Mi
    limits:
      memory: 1Gi
  autoscaling:
    enabled: true
    maxReplicas: 10

networkPolicy:
  enabled: true
