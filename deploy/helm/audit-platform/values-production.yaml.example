# Production overrides — copy to my-values.yaml and customize.
# helm upgrade --install audit deploy/helm/audit-platform -f my-values.yaml

global:
  deploymentEnvironment: production

images:
  api:
    repository: ghcr.io/YOUR_ORG/audit-api
    tag: "0.1.0"
    pullPolicy: IfNotPresent
  worker:
    repository: ghcr.io/YOUR_ORG/audit-worker
    tag: "0.1.0"
    pullPolicy: IfNotPresent
  web:
    repository: ghcr.io/YOUR_ORG/audit-web
    tag: "0.1.0"
    pullPolicy: IfNotPresent

postgresql:
  auth:
    password: ""  # leave empty for Bitnami-generated secret, or set explicitly

minio:
  auth:
    rootPassword: ""  # set for deterministic installs

ingress:
  enabled: true
  className: nginx
  host: app.yourdomain.com
  filesHost: files.yourdomain.com
  tls:
    enabled: true
    secretName: audit-platform-tls

secrets:
  adminApiToken: ""  # REQUIRED — pass via --set or external secret manager

config:
  corsOrigins: '["https://app.yourdomain.com"]'
  vllmBaseUrl: http://vllm.gpu.svc.cluster.local:8000/v1
  vllmServedModel: numind/NuExtract3

observability:
  sentryDsn: ""  # optional GlitchTip DSN

hatchet:
  postgresPassword: ""  # set explicitly in production
  bootstrapToken: true

workerOcr:
  replicas: 2
  autoscaling:
    enabled: true
    maxReplicas: 15

workerFast:
  replicas: 2
  autoscaling:
    enabled: true
    maxReplicas: 10
