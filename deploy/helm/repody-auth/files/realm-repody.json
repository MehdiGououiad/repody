{
  "realm": "repody",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": false,
  "roles": {
    "realm": [
      { "name": "platform_admin" },
      { "name": "admin" },
      { "name": "operator" },
      { "name": "viewer" }
    ]
  },
  "clients": [
    {
      "clientId": "repody-web",
      "name": "Repody Web",
      "enabled": true,
      "publicClient": false,
      "secret": "repody-web-dev-secret",
      "redirectUris": [
        "http://localhost:3000/api/auth/callback/keycloak",
        "http://localhost:8088/api/auth/callback/keycloak",
        "http://127.0.0.1:3000/api/auth/callback/keycloak",
        "http://127.0.0.1:8088/api/auth/callback/keycloak",
        "http://app.repody.local/api/auth/callback/keycloak",
        "http://*:3000/api/auth/callback/keycloak",
        "https://repody-web.apps-crc.testing/api/auth/callback/keycloak",
        "https://*-web.apps-crc.testing/api/auth/callback/keycloak"
      ],
      "webOrigins": [
        "http://localhost:3000",
        "http://localhost:8088",
        "http://127.0.0.1:3000",
        "http://127.0.0.1:8088",
        "http://app.repody.local",
        "https://repody-web.apps-crc.testing",
        "https://*-web.apps-crc.testing",
        "+"
      ],
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "protocol": "openid-connect",
      "fullScopeAllowed": true,
      "protocolMappers": [
        {
          "name": "repody-api-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "repody-api",
            "id.token.claim": "false",
            "access.token.claim": "true",
            "userinfo.token.claim": "false"
          }
        }
      ]
    },
    {
      "clientId": "repody-api",
      "name": "Repody API",
      "enabled": true,
      "bearerOnly": true,
      "protocol": "openid-connect"
    }
  ],
  "users": [
    {
      "username": "admin@repody.local",
      "firstName": "Platform",
      "lastName": "Admin",
      "email": "admin@repody.local",
      "enabled": true,
      "emailVerified": true,
      "requiredActions": [],
      "credentials": [
        { "type": "password", "value": "repody-dev", "temporary": false }
      ],
      "realmRoles": ["platform_admin"]
    },
    {
      "username": "operator@repody.local",
      "firstName": "Repody",
      "lastName": "Operator",
      "email": "operator@repody.local",
      "enabled": true,
      "emailVerified": true,
      "requiredActions": [],
      "credentials": [
        { "type": "password", "value": "repody-dev", "temporary": false }
      ],
      "realmRoles": ["operator"]
    },
    {
      "username": "viewer@repody.local",
      "firstName": "Repody",
      "lastName": "Viewer",
      "email": "viewer@repody.local",
      "enabled": true,
      "emailVerified": true,
      "requiredActions": [],
      "credentials": [
        { "type": "password", "value": "repody-dev", "temporary": false }
      ],
      "realmRoles": ["viewer"]
    }
  ]
}
