# Copy to paths.harbor.local.env (optional local env file — not committed).
# Harbor host must match harbor.yml hostname. Project name is the Harbor project (repody).

REPODY_HARBOR_HOST=harbor.yourdomain.com
REPODY_HARBOR_HTTP_PORT=443
REPODY_HARBOR_PROJECT=repody
REPODY_IMAGE_REGISTRY=harbor.yourdomain.com/repody
REPODY_HARBOR_ADMIN_PASSWORD=CHANGE_ME

# Install Harbor per official docs: docs/deploy/HARBOR.md
