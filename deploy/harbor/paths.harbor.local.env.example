# Copy to paths.harbor.local.env (created automatically by pnpm harbor:prepare).
# Default host uses lvh.me so Harbor works without editing the hosts file.

REPODY_HARBOR_HOST=harbor.repody.lvh.me
REPODY_HARBOR_HTTP_PORT=8080
REPODY_HARBOR_PROJECT=repody
REPODY_LOCAL_REGISTRY=harbor.repody.lvh.me:8080/repody
REPODY_HARBOR_ADMIN_PASSWORD=Harbor12345

# Optional: pin Harbor installer version (see harbor-local.mjs)
# REPODY_HARBOR_VERSION=2.11.2
