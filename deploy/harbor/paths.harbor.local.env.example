# Copy to paths.harbor.local.env and use with Harbor-backed local dev.
#   pnpm harbor:bootstrap
#   pnpm dev:harbor

REPODY_REGISTRY_MODE=harbor
REPODY_HARBOR_HOST=harbor.repody.local
REPODY_HARBOR_HTTP_PORT=8080
REPODY_HARBOR_PROJECT=repody
REPODY_LOCAL_REGISTRY=harbor.repody.local:8080/repody
REPODY_HARBOR_ADMIN_PASSWORD=Harbor12345

# Optional: pin Harbor installer version (see harbor-local.mjs)
# REPODY_HARBOR_VERSION=2.11.2
