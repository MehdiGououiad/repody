# Copy to backend/.env for Compose local dev.
# Also copy deploy/env.auth.example → repo-root .env.local (Next.js / Auth.js).
# See docs/deploy/LOCAL.md

AUDIT_DATABASE_URL=postgresql+asyncpg://audit:audit-local-dev@127.0.0.1:5432/audit_workbench
AUDIT_REDIS_URL=redis://127.0.0.1:6379/0
AUDIT_STORAGE_BACKEND=s3
AUDIT_MINIO_ENDPOINT=127.0.0.1:9000
AUDIT_MINIO_BUCKET=audit-documents
AUDIT_MINIO_ACCESS_KEY=minioadmin
AUDIT_MINIO_SECRET_KEY=minio-local-dev
AUDIT_MINIO_SECURE=false
AUDIT_SEED_ON_STARTUP=true
AUDIT_RUN_MIGRATIONS_ON_STARTUP=true

# Inference — llama-server on 8081 (API uses 8000). See deploy/llamacpp/README.md
AUDIT_VLLM_BASE_URL=http://127.0.0.1:8081/v1
AUDIT_VLLM_SERVED_MODEL=nuextract3-q4_k_m
AUDIT_INFERENCE_MODE=vllm

# Repody VLM — NuExtract official: 170 DPI PNG, thinking off, logic-only validation
AUDIT_REPODY_VLM_PDF_DPI=170
AUDIT_REPODY_VLM_ENABLE_THINKING=false
AUDIT_REPODY_VLM_WARMUP_ON_START=false
AUDIT_EXTRACTION_CACHE_ENABLED=false
AUDIT_LLM_VALIDATION_ENABLED=false

# Admission control — keep local OCR runs close to worker capacity.
AUDIT_ADMISSION_MAX_QUEUED=50
AUDIT_ADMISSION_MAX_INFLIGHT=32
AUDIT_ADMISSION_MAX_OCR_INFLIGHT=2
AUDIT_ADMISSION_RETRY_AFTER_SECONDS=60

# Keycloak OIDC (Compose keycloak service on :8080)
AUDIT_OIDC_ENABLED=true
AUDIT_OIDC_ISSUER=http://localhost:8080/realms/repody
AUDIT_OIDC_ISSUER_ALIASES=http://127.0.0.1:8080/realms/repody
AUDIT_OIDC_JWKS_URL=http://localhost:8080/realms/repody/protocol/openid-connect/certs
AUDIT_OIDC_AUDIENCE=repody-api
AUDIT_KEYCLOAK_ADMIN_URL=http://localhost:8080
AUDIT_KEYCLOAK_ADMIN_USER=admin
AUDIT_KEYCLOAK_ADMIN_PASSWORD=admin
AUDIT_KEYCLOAK_CLIENT_ID=repody-web
AUDIT_KEYCLOAK_CLIENT_SECRET=repody-web-dev-secret
AUDIT_OPERATOR_BENCHMARK_USER=operator@repody.local
AUDIT_OPERATOR_BENCHMARK_PASSWORD=repody-dev

AUTH_SECRET=local-dev-auth-secret-32chars-min!
AUTH_URL=http://localhost:3000
