# Copy to backend/.env for Compose local dev.
# Also copy deploy/env.auth.example → repo-root .env.local (Next.js / Auth.js).
# See docs/deploy/LOCAL.md

AUDIT_DATABASE_URL=postgresql+asyncpg://audit:audit-local-dev@127.0.0.1:5432/audit_workbench
AUDIT_REDIS_URL=redis://127.0.0.1:6379/0
AUDIT_STORAGE_BACKEND=s3
AUDIT_MINIO_ENDPOINT=127.0.0.1:9000
AUDIT_MINIO_BUCKET=audit-documents
AUDIT_MINIO_ACCESS_KEY=minioadmin
AUDIT_MINIO_SECRET_KEY=minio-local-dev
AUDIT_MINIO_SECURE=false
# Seed once via `pnpm dev:setup` / `pnpm db:reset` — keep false for faster API restarts.
AUDIT_SEED_ON_STARTUP=false
# Host uvicorn ignores this; Docker entrypoint may still migrate. Prefer `pnpm db:migrate`.
AUDIT_RUN_MIGRATIONS_ON_STARTUP=false

# Inference — llama-server on 8081 (API uses 8000). See deploy/llamacpp/README.md
AUDIT_LLAMACPP_BASE_URL=http://127.0.0.1:8081/v1
AUDIT_LLAMACPP_SERVED_MODEL=nuextract3-q4_k_m
AUDIT_INFERENCE_MODE=llamacpp

# NuExtract render policy is fixed in code (170 DPI PNG). See docs/REPODY-VLM.md
AUDIT_REPODY_VLM_WARMUP_ON_START=false

# Set true in production; false for honest extraction benchmarks (no Redis result cache)
AUDIT_EXTRACTION_CACHE_ENABLED=false
AUDIT_LLM_VALIDATION_ENABLED=false

# Extract run timeouts — hard cap 3 min per task; VLM HTTP must fit inside worker ceiling.
AUDIT_REPODY_VLM_TIMEOUT_SECONDS=180
AUDIT_WORKER_TASK_TIMEOUT_MINUTES=3
AUDIT_STALE_RUN_TIMEOUT_MINUTES=5
AUDIT_QUEUED_STALE_TIMEOUT_MINUTES=60

# Admission control — keep local extract runs close to worker capacity.
AUDIT_ADMISSION_MAX_QUEUED=50
AUDIT_ADMISSION_MAX_INFLIGHT=32
AUDIT_ADMISSION_MAX_EXTRACT_INFLIGHT=2
AUDIT_ADMISSION_RETRY_AFTER_SECONDS=60

# Structured JSON logs (default — Loki / production parity)
AUDIT_LOG_JSON=true

# Optional observability — started by `pnpm dev:all` (default) or `pnpm dev:observability`
# Grafana http://localhost:3030 · Bugsink http://localhost:8090 · OTLP http://localhost:4318/v1/traces
# AUDIT_OTEL_ENABLED=true
# AUDIT_OTEL_EXPORTER_ENDPOINT=http://127.0.0.1:4318/v1/traces
# AUDIT_OTEL_SERVICE_NAME=repody-api
# Host API log file (Promtail → Loki when observability profile is running)
# AUDIT_LOG_FILE=../.logs/repody-api.log

# Bugsink — create a project at http://localhost:8090, then paste DSN (see docs/BUGSINK.md)
# BUGSINK_DSN=http://<key>@127.0.0.1:8090/<project-id>
# For Compose workers, also set the same DSN in repo-root `.env` using host.docker.internal:8090

# Keycloak OIDC (Compose keycloak service on :8080)
AUDIT_OIDC_ENABLED=true
AUDIT_OIDC_ISSUER=http://localhost:8080/realms/repody
AUDIT_OIDC_ISSUER_ALIASES=http://127.0.0.1:8080/realms/repody
AUDIT_OIDC_JWKS_URL=http://localhost:8080/realms/repody/protocol/openid-connect/certs
AUDIT_OIDC_AUDIENCE=repody-api
AUDIT_KEYCLOAK_ADMIN_URL=http://localhost:8080
AUDIT_KEYCLOAK_ADMIN_USER=admin
AUDIT_KEYCLOAK_ADMIN_PASSWORD=admin
AUDIT_KEYCLOAK_CLIENT_ID=repody-web
AUDIT_KEYCLOAK_CLIENT_SECRET=repody-web-dev-secret
AUDIT_OPERATOR_BENCHMARK_USER=operator@repody.local
AUDIT_OPERATOR_BENCHMARK_PASSWORD=repody-dev

AUTH_SECRET=local-dev-auth-secret-32chars-min!
AUTH_URL=http://localhost:3000
