# Copy to deploy/llamacpp/surya-paths.local.env (not committed).
# Then: pnpm llamacpp:surya:serve && pnpm llamacpp:surya:verify
#
# Weights: https://huggingface.co/datalab-to/surya-ocr-2-gguf

# winget install llama.cpp — or full path to llama-server.exe
SURYA_LLAMACPP_EXE=

SURYA_LLAMACPP_MODEL=C:\path\to\surya-2.gguf
SURYA_LLAMACPP_MMPROJ=C:\path\to\surya-2-mmproj.gguf

# Separate port from NuExtract (pnpm llamacpp:serve uses 8000)
SURYA_LLAMACPP_PORT=8001
SURYA_LLAMACPP_PARALLEL=8
# datalab-to/surya SURYA_INFERENCE_CTX_PER_SLOT (total ctx = max(16384, parallel × per_slot))
SURYA_LLAMACPP_CTX_PER_SLOT=12288
SURYA_LLAMACPP_GPU_LAYERS=99
SURYA_LLAMACPP_ALIAS=datalab-to/surya-ocr-2

# From: llama-server --list-devices (e.g. Vulkan0, CUDA0)
SURYA_LLAMACPP_DEVICE=Vulkan0
