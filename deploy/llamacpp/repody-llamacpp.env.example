# Point Repody workers at host llama-server (kind / Docker Desktop).
# Full guide: deploy/llamacpp/README.md

AUDIT_INFERENCE_MODE=llamacpp
AUDIT_LLAMACPP_BASE_URL=http://host.docker.internal:8081/v1
AUDIT_LLAMACPP_SERVED_MODEL=nuextract3-q4_k_m

AUDIT_REPODY_VLM_ENABLED=true
AUDIT_DEFAULT_DOCUMENT_MODEL_ID=repody:vlm
AUDIT_REPODY_VLM_TIMEOUT_SECONDS=180
AUDIT_REPODY_VLM_MAX_PAGES_PER_REQUEST=6
AUDIT_REPODY_VLM_WARMUP_ON_START=false
