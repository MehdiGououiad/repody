# Copy to deploy/llamacpp/paths.local.env (not committed).
# Then: pnpm llamacpp:serve && pnpm llamacpp:verify
#
# Keep LLAMACPP_MODEL_ALIAS in sync with:
#   backend/.env AUDIT_VLLM_SERVED_MODEL
#   compose.yaml worker-ocr AUDIT_VLLM_SERVED_MODEL

# winget install llama.cpp — or full path to llama-server.exe
LLAMACPP_EXE=

LLAMACPP_MODEL=C:\path\to\NuExtract3-Q4_K_M.gguf
LLAMACPP_MMPROJ=C:\path\to\mmproj-NuExtract3-BF16.gguf
LLAMACPP_MODEL_ALIAS=nuextract3-q4_k_m

# OpenAI-compatible API (Repody API uses :8000 — keep llama-server on :8081)
LLAMACPP_PORT=8081
LLAMACPP_CONTEXT=16384
LLAMACPP_GPU_LAYERS=99

# From: llama-server --list-devices (e.g. Vulkan0, CUDA0)
LLAMACPP_DEVICE=Vulkan0

# speed (default): Q4 + Vulkan — ~7–13s warm extraction on Arc; use stability after ErrorDeviceLost
LLAMACPP_PROFILE=speed
# LLAMACPP_PROFILE=stability

# NuExtract official: image-min-tokens 1024 for Qwen-VL grounding (HF model card / llama.cpp #16842)
LLAMACPP_PARALLEL=1
LLAMACPP_IMAGE_MIN_TOKENS=1024
LLAMACPP_IMAGE_MAX_TOKENS=2048

# Intel Arc / Vulkan tuned defaults (see docs/deploy/LOCAL.md):
LLAMACPP_UBATCH=1024
LLAMACPP_MTMD_BATCH_MAX_TOKENS=1024
LLAMACPP_FLASH_ATTN=on
LLAMACPP_CACHE_TYPE_K=q8_0
LLAMACPP_CACHE_TYPE_V=q8_0
LLAMACPP_VK_MAX_NODES_PER_SUBMIT=1
LLAMACPP_CACHE_RAM_MIB=2048
LLAMACPP_CACHE_PROMPT=on
LLAMACPP_FIT=on
# Prime Facture + schema after serve (official NuExtract dev path — cuts cold first extraction)
LLAMACPP_WARMUP=on
