# Copy to repo-root .env.local for Compose / local OIDC (Keycloak on :8080).
# Backend OIDC vars live in deploy/env/compose.env.example → backend/.env
#
# Use localhost (not 127.0.0.1) for browser auth — see docs/deploy/LOCAL.md

AUTH_SECRET=local-dev-auth-secret-32chars-min!
AUTH_URL=http://localhost:3000
AUTH_KEYCLOAK_ID=repody-web
AUTH_KEYCLOAK_CLIENT_SECRET=repody-web-dev-secret
AUTH_KEYCLOAK_SECRET=repody-web-dev-secret
AUTH_KEYCLOAK_ISSUER=http://localhost:8080/realms/repody

KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_HTTP_PORT=8080
KEYCLOAK_HOSTNAME=localhost

BACKEND_URL=http://127.0.0.1:8000
