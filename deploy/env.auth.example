# Copy to repo-root .env and .env.local for local OIDC dev.
#   cp deploy/env.auth.example .env
# Then set AUTH_SECRET (unique per machine) and mirror Auth.js vars into .env.local.

AUTH_SECRET=replace-with-openssl-rand-base64-32
AUTH_URL=http://localhost:3000
AUTH_KEYCLOAK_ID=repody-web
AUTH_KEYCLOAK_CLIENT_SECRET=repody-web-dev-secret
AUTH_KEYCLOAK_SECRET=repody-web-dev-secret
AUTH_KEYCLOAK_ISSUER=http://127.0.0.1:8080/realms/repody

KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_HTTP_PORT=8080
KEYCLOAK_HOSTNAME=127.0.0.1

AUDIT_OIDC_ENABLED=true
AUDIT_OIDC_ISSUER=http://127.0.0.1:8080/realms/repody
AUDIT_OIDC_JWKS_URL=http://keycloak:8080/realms/repody/protocol/openid-connect/certs
AUDIT_OIDC_AUDIENCE=repody-api

BACKEND_URL=http://127.0.0.1:8000
