# Pinned local/dev container image tags.
# Enterprise production uses client-managed data, queue, auth, observability, and inference services.
# See docs/VERSIONS.md.

# Local/dev data plane
REPODY_POSTGRES_IMAGE=postgres:17.10-alpine
REPODY_REDIS_IMAGE=redis:8.8.0-alpine
REPODY_MINIO_IMAGE=pgsty/minio:RELEASE.2026-04-17T00-00-00Z

# Hatchet stack (official chart) for local/dev. Production uses externalHatchet.
REPODY_HATCHET_API_IMAGE=ghcr.io/hatchet-dev/hatchet/hatchet-api:v0.84.0
REPODY_HATCHET_ENGINE_IMAGE=ghcr.io/hatchet-dev/hatchet/hatchet-engine:v0.84.0
REPODY_HATCHET_FRONTEND_IMAGE=ghcr.io/hatchet-dev/hatchet/hatchet-frontend:v0.84.0
REPODY_HATCHET_MIGRATE_IMAGE=ghcr.io/hatchet-dev/hatchet/hatchet-migrate:v0.84.0
REPODY_HATCHET_ADMIN_IMAGE=ghcr.io/hatchet-dev/hatchet/hatchet-admin:v0.84.0
REPODY_BITNAMI_POSTGRES_IMAGE=bitnamilegacy/postgresql:17.6.0-debian-12-r4
REPODY_BITNAMI_RABBITMQ_IMAGE=bitnamilegacy/rabbitmq:4.1.3-debian-12-r1

# Local/dev auth
REPODY_KEYCLOAK_IMAGE=quay.io/keycloak/keycloak:26.6.3

# Local/dev observability
REPODY_LOKI_IMAGE=grafana/loki:3.6.11
REPODY_PROMTAIL_IMAGE=grafana/promtail:3.6.11
REPODY_GRAFANA_IMAGE=grafana/grafana:12.4.1
REPODY_TEMPO_IMAGE=grafana/tempo:2.9.2

# Local/dev Sentry-compatible error tracking
REPODY_BUGSINK_IMAGE=bugsink/bugsink:2

# Local/dev edge and inference helpers
REPODY_CADDY_IMAGE=caddy:2.11.4-alpine
REPODY_VLLM_IMAGE=vllm/vllm-openai:latest

# K8s local bootstrap utilities
REPODY_BUSYBOX_IMAGE=busybox:1.37.0
REPODY_KUBECTL_IMAGE=dtzar/helm-kubectl:3.18.6

# Argo CD install pin (deploy/argocd/kustomize/local)
ARGO_CD_VERSION=v3.4.4
