# Pinned container image tags — single source of truth for Compose overlays.
# Bump here, then grep compose*.yaml / deploy/helm for drift.
# See docs/VERSIONS.md

# Data plane
REPODY_POSTGRES_IMAGE=postgres:17.10-alpine
REPODY_REDIS_IMAGE=redis:8.8.0-alpine
# minio/minio is archived; pgsty/minio is the maintained OSS fork with security patches.
REPODY_MINIO_IMAGE=pgsty/minio:RELEASE.2026-04-17T00-00-00Z

# Hatchet (self-hosted)
REPODY_HATCHET_LITE_IMAGE=ghcr.io/hatchet-dev/hatchet/hatchet-lite:latest
REPODY_HATCHET_ADMIN_IMAGE=ghcr.io/hatchet-dev/hatchet/hatchet-admin:latest
REPODY_HATCHET_POSTGRES_IMAGE=postgres:17.10-alpine

# Auth
REPODY_KEYCLOAK_IMAGE=quay.io/keycloak/keycloak:26.6.3

# Observability (Promtail EOL 2026-03 — migrate to Grafana Alloy later)
REPODY_LOKI_IMAGE=grafana/loki:3.6.11
REPODY_PROMTAIL_IMAGE=grafana/promtail:3.6.11
REPODY_GRAFANA_IMAGE=grafana/grafana:12.4.1
REPODY_TEMPO_IMAGE=grafana/tempo:2.9.2

# Bugsink (self-hosted Sentry-compatible error tracking)
REPODY_BUGSINK_IMAGE=bugsink/bugsink:2

# Edge / GPU
REPODY_CADDY_IMAGE=caddy:2.11.4-alpine
REPODY_VLLM_IMAGE=vllm/vllm-openai:latest

# K8s bootstrap utilities
REPODY_BUSYBOX_IMAGE=busybox:1.37.0
REPODY_KUBECTL_IMAGE=dtzar/helm-kubectl:3.18.6
